amends "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Builtins.pkl"

local allSteps = new Mapping<String, Step> {
  // formatters
  ["dprint"] = Builtins.dprint
  ["pkl_format"] = Builtins.pkl_format

  // linters
  ["ruff"] = Builtins.ruff
  ["ty"] = Builtins.ty
  ["pkl"] = Builtins.pkl

  // schema
  ["schema_gen"] {
    glob = "aslankigen/models.py"
    check = "python -m aslankigen.schema --check"
    fix = "python -m aslankigen.schema"
  }
  ["jvl"] {
    depends = List("schema_gen")
    glob = "words.json"
    check = "jvl check --strict {{files}}"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = allSteps
  }
  ["fix"] {
    fix = true
    steps = allSteps
  }
  ["check"] {
    steps = allSteps
  }
}
